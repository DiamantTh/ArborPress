# ==============================================================================
# ArborPress – Umgebungsvariablen für Docker Compose
# Datei kopieren nach .env und alle Werte anpassen.
# .env NIEMALS ins Git einchecken!
# ==============================================================================

# ── Web / Sicherheit ──────────────────────────────────────────────────────────

# Langen Zufallsstring verwenden (mind. 32 Zeichen).
# Generieren: openssl rand -base64 48
ARBORPRESS_WEB__SECRET_KEY=AENDERN_IM_PRODUKTIVBETRIEB_langer_zufaelliger_string

# Öffentliche URL des Blogs (für Cookie-Sicherheit und interne Links)
ARBORPRESS_WEB__BASE_URL=https://blog.example.com

# Anzahl vorgelagerter Reverse-Proxy-Hops (Standard: 1).
# 0 setzen, wenn ArborPress ohne Proxy direkt erreichbar ist.
ARBORPRESS_WEB__TRUSTED_PROXIES=1

# ── Port-Mapping ──────────────────────────────────────────────────────────────

# Host-Port, auf dem ArborPress erreichbar ist (Compose-Mapping: ARBORPRESS_PORT:8080)
ARBORPRESS_PORT=8080

# ── Datenbank-Zugangsdaten ────────────────────────────────────────────────────

# ── PostgreSQL (container/compose.postgresql.yml / container/compose.postgresql.ubuntu.yml) ──
POSTGRES_USER=arborpress
POSTGRES_DB=arborpress
# Sicheres Passwort für den Anwendungsbenutzer
# Generieren: openssl rand -base64 32
POSTGRES_PASSWORD=AENDERN_sicheres_db_passwort

# ── MariaDB (container/compose.mariadb.yml / container/compose.mariadb.ubuntu.yml) ────
MARIADB_USER=arborpress
MARIADB_DATABASE=arborpress
# Sicheres Passwort für den Anwendungsbenutzer
MARIADB_PASSWORD=AENDERN_sicheres_db_passwort
# Passwort für den MariaDB-Root-Benutzer
MARIADB_ROOT_PASSWORD=AENDERN_sicheres_root_passwort

# ── Logging ───────────────────────────────────────────────────────────────────

# Log-Level: DEBUG | INFO | WARNING | ERROR
ARBORPRESS_LOGGING__LEVEL=INFO

# ── Worker ────────────────────────────────────────────────────────────────────

# Anzahl Hypercorn-Worker-Prozesse (mind. 2 für Produktion empfohlen)
ARBORPRESS_WORKERS=2

# ── Optionaler Redis-Cache ────────────────────────────────────────────────────

# Redis aktivieren: auskommentierte Zeilen einkommentieren und
# einen redis-Service in der Compose-Datei ergänzen.
# ARBORPRESS_CACHE__BACKEND=redis
# ARBORPRESS_CACHE__REDIS_URL=redis://redis:6379/0
